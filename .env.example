# Database
# For local dev (pnpm dev) use an absolute path — Prisma resolves relative
# paths from the cwd of whichever app is running.
# Example Windows: DATABASE_URL=file:C:/path/to/StreamFlare/packages/db/prisma/dev.db
# Example macOS/Linux: DATABASE_URL=file:/path/to/StreamFlare/packages/db/prisma/dev.db
# In Docker this is `file:/data/streamflare.db` (set in docker-compose.yml).
DATABASE_URL=file:./packages/db/prisma/dev.db

# API
JWT_SECRET=replace-me-with-a-long-random-string
TMDB_API_KEY=replace-me-with-your-tmdb-key

# Web
NEXT_PUBLIC_API_URL=http://localhost:5000

# ML Service URL (used by API to call ML)
ML_SERVICE_URL=http://localhost:5001
