{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@streamflare/ui": ["../../packages/ui/src/index.ts"],
      "@streamflare/ui/components": ["../../packages/ui/src/components"],
      "@streamflare/ui/components/*": ["../../packages/ui/src/components/*"],
      "@streamflare/ui/lib": ["../../packages/ui/src/lib"],
      "@streamflare/ui/lib/*": ["../../packages/ui/src/lib/*"],
      "@streamflare/ui/hooks": ["../../packages/ui/src/hooks"],
      "@streamflare/ui/hooks/*": ["../../packages/ui/src/hooks/*"],
      "@streamflare/ui/motion": ["../../packages/ui/src/motion/index.tsx"]
    },
    "allowJs": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
